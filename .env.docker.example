# PicTur – Docker Compose environment
# Copy to .env and adjust. Used by: docker compose up

# ----- Shared (must match between auth-backend and backend) -----
JWT_SECRET=your-secret-key-change-in-production

# ----- Frontend port (host port; default 80) -----
# If port 80 is in use: FRONTEND_PORT=8080 and FRONTEND_URL=http://localhost:8080 (below)

# ----- Auth Backend -----
FRONTEND_URL=http://localhost
SESSION_SECRET=change-me-in-production
# Optional: Google OAuth (set GOOGLE_CLIENT_ID and GOOGLE_CLIENT_SECRET, then in Google Cloud Console
# add this as "Authorized redirect URI": http://localhost:3001/api/auth/google/callback)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
#
# Optional: real email (verification, invitations). If unset, auth-backend logs emails to the console.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@yourdomain.example
#
# ----- Production / public host (required when not opening the app on the same machine as Docker) -----
# Browsers use the URLs below; "localhost" in the built JS points at the user's PC, not your server.
# FRONTEND_URL=https://your-domain.example
# If Google / users reach auth on a public host or port, set one of:
# GOOGLE_CALLBACK_URL=https://your-domain.example:3001/api/auth/google/callback
#   OR same path via reverse proxy on 443, e.g. https://your-domain.example/api/auth/google/callback
# AUTH_BACKEND_URL=https://your-domain.example:3001
# With Caddy/NGINX on 80/443 only, either open 3001+5000 in the firewall or proxy /api/auth → auth-backend
# and /api → Flask (match path order: /api/auth before /api).

# ----- Frontend (build-time API URLs; only needed if not using localhost) -----
# VITE_AUTH_API_URL=http://localhost:3001/api
# VITE_API_URL=http://localhost:5000/api

# ----- Backend (Google Sheets) -----
GOOGLE_SHEETS_SPREADSHEET_ID=
# Community spreadsheet for confirmed turtle data (required for community uploads)
GOOGLE_SHEETS_COMMUNITY_SPREADSHEET_ID=
# Path inside container. Host dir backend/credentials is mounted to /app/credentials.
# Put your Service Account JSON in backend/credentials/; use this filename or set:
# GOOGLE_SHEETS_CREDENTIALS_PATH=/app/credentials/your-actual-filename.json
GOOGLE_SHEETS_CREDENTIALS_PATH=/app/credentials/google-sheets-credentials.json

# ----- Optional GPU runtime -----
# For GPU compose override, you can set this if needed:
# CUDA_VISIBLE_DEVICES=all
